# NODE_ENV is usually injected by the platform; keep for local dev

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

########################################################
# Database Configuration (PostgreSQL)
# Dev Database
########################################################
DATABASE_URL=postgresql://kavach_user:your_secure_password@localhost:5432/kavach_auth
# Production Database URL (use this for production deployments)
# DATABASE_URL=postgresql://kavach_user:your_secure_password@localhost:5432/kavach_auth

########################################################
# Authentication / Crypto Secrets
# Use long, randomly generated secrets (>= 32 bytes entropy)
########################################################
JWT_SECRET=replace-with-a-strong-random-secret
SESSION_SECRET=replace-with-a-strong-random-session-secret

########################################################
# Email Configuration (SMTP)
# For Gmail: enable App Passwords. SMTP_SECURE=true usually for port 465.
########################################################
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM="Kavach <no-reply@kavach.com>"

# Email Verification Configuration
EMAIL_VERIFICATION_TYPE="magic_link"
EMAIL_VERIFICATION_MAGIC_LINK_EXPIRATION_HOURS="1"

########################################################
# Admin Bootstrapping (seed scripts)
########################################################
ADMIN_EMAIL=admin@kavach.com
ADMIN_PASSWORD=

########################################################
# Feature Flags (initially unused; safe defaults)
########################################################
# FEATURE_REFRESH_TOKENS=false

########################################################
# Rate Limiting Configuration
########################################################
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_ATTEMPTS=5

########################################################
# Logging / Observability
########################################################
LOG_LEVEL=info

########################################################
# Security Headers / CSP Overrides (future)
########################################################
# CSP_EXTRA=script-src 'self'

########################################################
# Testing Overrides (Vitest) - usually set in test env only
########################################################
# TEST_DATABASE_URL=postgresql://kavach_test:password@localhost:5432/kavach_auth_test
